{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@drr/shared": ["packages/shared/src/index.ts"],
      "@drr/parsers": ["packages/parsers/src/index.ts"],
      "@drr/providers": ["packages/providers/src/index.ts"],
      "@drr/scoring": ["packages/scoring/src/index.ts"],
      "@drr/policy": ["packages/policy/src/index.ts"],
      "@drr/reporters": ["packages/reporters/src/index.ts"],
      "@drr/core": ["packages/core/src/index.ts"]
    }
  }
}
